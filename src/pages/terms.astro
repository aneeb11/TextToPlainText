---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Terms & Conditions — Text to Plain Text";
const description = "The terms and conditions for using Text to Plain Text.";
---

<BaseLayout title={title} description={description}>
	<div class="max-w-[700px] mx-auto py-20 px-6">
		<header class="mb-12">
			<h1 class="text-display-lg mb-4">Terms & Conditions</h1>
			<p class="text-body-lg text-body">
				By using Text to Plain Text, you agree to the following terms. We've kept them simple and transparent.
			</p>
		</header>

		<div class="space-y-8">
			<section>
				<h2 class="text-display-sm mb-3">1. Use of Service</h2>
				<p class="text-body-md text-body">
					Text to Plain Text is provided as-is for personal and professional use. You are responsible for any text you process through our tools.
				</p>
			</section>

			<section>
				<h2 class="text-display-sm mb-3">2. No Liability</h2>
				<p class="text-body-md text-body">
					Since all processing happens in your browser, we do not store or see your data. We are not liable for any data loss, corruption, or unintended consequences resulting from the use of our tools.
				</p>
			</section>

			<section>
				<h2 class="text-display-sm mb-3">3. Open Source & Contributions</h2>
				<p class="text-body-md text-body">
					The software is open-source. While you are free to inspect and contribute to the code, the name "Text to Plain Text" and its branding are protected.
				</p>
			</section>

			<section>
				<h2 class="text-display-sm mb-3">4. Changes to Terms</h2>
				<p class="text-body-md text-body">
					We reserve the right to modify these terms at any time. Your continued use of the site constitutes acceptance of the updated terms.
				</p>
			</section>

			<section class="pt-8 border-t border-hairline">
				<p class="text-caption text-mute italic">
					Last Updated: January 2026
				</p>
			</section>
		</div>
	</div>
</BaseLayout>
