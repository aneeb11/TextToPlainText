---
import BaseLayout from "../layouts/BaseLayout.astro";
import Workspace from "../components/Workspace.astro";

const title = "JSON Minifier — Compress JSON Online";
const description = "Minify and compress your JSON data to reduce file size. Our JSON Minifier removes all unnecessary whitespace and formatting for production use.";
---

<BaseLayout title={title} description={description}>
	<Workspace 
		title="JSON Minifier" 
		description="Paste your JSON below to strip all whitespace and minify it for production." 
        placeholder='{ "key": "value" }'
	>
		<div slot="controls">
			<button
				id="minify-json-btn"
                data-action="minify-json"
				class="w-full h-10 px-4 flex items-center justify-between text-body-sm-strong bg-ink text-canvas rounded-md hover:opacity-90 transition-opacity group"
			>
				Minify JSON
				<span class="text-[10px] bg-canvas/20 px-1.5 py-0.5 rounded uppercase tracking-wider group-hover:bg-canvas/30 transition-colors">Action</span>
			</button>
		</div>
	</Workspace>

    <!-- FAQ Section -->
    <section id="faq" class="max-w-[800px] mx-auto px-6 py-20 border-t border-hairline scroll-mt-20">
        <h2 class="text-display-md mb-8 text-center">Frequently Asked Questions</h2>
        
        <div class="space-y-6">
            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Why should I minify JSON?</h3>
                <p class="text-body-md text-body">
                    Minifying JSON reduces the payload size of API responses and configuration files by removing whitespace, tabs, and newlines. This leads to faster data transfer and reduced bandwidth usage in production environments.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Does minification change the data?</h3>
                <p class="text-body-md text-body">
                    No. Minification only affects the formatting (the "pretty" parts). The data structure, keys, and values remain exactly the same. It is a non-destructive process.
                </p>
            </div>
        </div>
    </section>

    <script>
        document.getElementById('minify-json-btn')?.addEventListener('click', () => {
            const textarea = document.getElementById('workspace-textarea') as HTMLTextAreaElement;
            if (!textarea) return;
            
            try {
                const parsed = JSON.parse(textarea.value);
                textarea.value = JSON.stringify(parsed);
                textarea.dispatchEvent(new CustomEvent('workspace:complete'));
            } catch (e) {
                textarea.classList.add('border-red-500');
                setTimeout(() => textarea.classList.remove('border-red-500'), 1000);
            }
        });
    </script>
</BaseLayout>
