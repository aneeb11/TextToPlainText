---
import BaseLayout from "../layouts/BaseLayout.astro";
import Workspace from "../components/Workspace.astro";

const title = "Strip Emojis — Free Online Strip Emojis | Text to Plain Text";
const description = "Instantly remove emojis, symbols, and special characters from your text blocks. A fast, privacy-first tool for cleaning and sanitizing your data.";
---

<BaseLayout title={title} description={description}>
    <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "What is Strip Emojis?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Strip Emojis is a utility designed to instantly remove all emojis, symbols, and special characters from your text, leaving behind clean, alphanumeric content."
        }
      }, {
        "@type": "Question",
        "name": "How does Strip Emojis work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The tool scans your text for Unicode characters that represent emojis and non-standard symbols and removes them, leaving only the text content."
        }
      }, {
        "@type": "Question",
        "name": "Is Strip Emojis free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, this tool is part of the Text to Plain Text suite and is completely free to use without any limitations or account requirements."
        }
      }, {
        "@type": "Question",
        "name": "Is Strip Emojis safe?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. Like all our tools, processing happens entirely in your browser. Your data is never uploaded to any server, ensuring total privacy."
        }
      }]
    }
    </script>

	<Workspace 
		title="Strip Emojis & Symbols" 
		description="Purge all emojis and non-alphanumeric symbols from your text string instantly." 
		id="strip-emojis"
	>
		<div slot="controls">
			<button
				id="strip-emojis-btn"
				class="w-full h-10 px-4 flex items-center justify-between text-body-sm-strong bg-ink text-canvas rounded-md hover:opacity-90 transition-opacity group"
			>
				Strip Emojis
				<span class="text-[10px] bg-canvas/20 px-1.5 py-0.5 rounded uppercase tracking-wider group-hover:bg-canvas/30 transition-colors">Action</span>
			</button>
		</div>

	<section id="faq" class="max-w-[800px] mx-auto px-6 py-20 border-t border-hairline scroll-mt-20">
        <h2 class="text-display-md mb-8 text-center">Frequently Asked Questions</h2>
        
        <div class="space-y-6">
            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">What is Strip Emojis?</h3>
                <p class="text-body-md text-body">
                    Strip Emojis is a utility designed to instantly remove all emojis, symbols, and special characters from your text, leaving behind clean, alphanumeric content.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">How does Strip Emojis work?</h3>
                <p class="text-body-md text-body">
                    The tool scans your text for Unicode characters that represent emojis and non-standard symbols and removes them, leaving only the text content.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is Strip Emojis free?</h3>
                <p class="text-body-md text-body">
                    Yes, this tool is part of the Text to Plain Text suite and is completely free to use. There are no daily limits, premium features, or sign-up requirements.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is Strip Emojis safe?</h3>
                <p class="text-body-md text-body">
                    Absolutely. Our tool operates entirely client-side using JavaScript. This means your text never leaves your browser and is never stored on our servers, ensuring your data remains private and secure.
                </p>
            </div>
        </div>
    </section>
	</Workspace>

<script is:inline>
        const btn = document.getElementById('strip-emojis-btn');
        const textarea = document.getElementById('strip-emojis');
        btn.addEventListener('click', () => {
            textarea.dispatchEvent(new Event('workspace:save'));
            const text = textarea.value;
            const cleaned = text.replace(/([\u2700-\u27BF]|[\uE000-\uF8FF]|\uD83C[\uDC00-\uDFFF]|\uD83D[\uDC00-\uDFFF]|[\u2011-\u26FF]|\uD83E[\uDD10-\uDDFF])/g, '');
            textarea.value = cleaned;
            textarea.dispatchEvent(new Event('workspace:complete'));
        });
    </script>
</BaseLayout>
