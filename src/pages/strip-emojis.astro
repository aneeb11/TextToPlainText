---
import BaseLayout from "../layouts/BaseLayout.astro";
import Workspace from "../components/Workspace.astro";

const title = "Strip Emojis From Text — Remove Symbols Online";
const description = "Instantly remove all emojis, symbols, and special characters from your text to leave only clean alphanumeric content.";
---

<BaseLayout title={title} description={description}>
	<Workspace 
		title="Strip Emojis & Symbols" 
		description="Purge all emojis and non-alphanumeric symbols from your text string instantly." 
		id="strip-emojis"
	>
		<div slot="controls">
			<button
				id="strip-emojis-btn"
				class="w-full h-10 px-4 flex items-center justify-between text-body-sm-strong bg-ink text-canvas rounded-md hover:opacity-90 transition-opacity group"
			>
				Strip Emojis
				<span class="text-[10px] bg-canvas/20 px-1.5 py-0.5 rounded uppercase tracking-wider group-hover:bg-canvas/30 transition-colors">Action</span>
			</button>
		</div>
	</Workspace>
</BaseLayout>

<script is:inline>
	const btn = document.getElementById('strip-emojis-btn');
	const textarea = document.getElementById('strip-emojis');

	btn.addEventListener('click', () => {
		textarea.dispatchEvent(new Event('workspace:save'));
		const text = textarea.value;
		// Regex to remove emojis and non-standard symbols, keeping alphanumeric and basic punctuation
        // This is a common pattern for stripping emojis
		const cleaned = text.replace(/([\u2700-\u27BF]|[\uE000-\uF8FF]|\uD83C[\uDC00-\uDFFF]|\uD83D[\uDC00-\uDFFF]|[\u2011-\u26FF]|\uD83E[\uDD10-\uDDFF])/g, '');
            
		textarea.value = cleaned;
        textarea.dispatchEvent(new Event('workspace:complete'));
	});
</script>
