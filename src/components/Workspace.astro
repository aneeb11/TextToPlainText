---
interface Props {
	title: string;
	description: string;
	placeholder?: string;
    id: string;
}

const { title, description, placeholder = "Paste your text here...", id } = Astro.props;
---

<div class="max-w-[1400px] mx-auto px-4 md:px-8 py-12">
	<div class="mb-8">
		<h1 class="text-display-lg tracking-tight mb-2">{title}.</h1>
		<p class="text-body-lg text-body">{description}</p>
	</div>

	<div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
		<!-- Main Text Area -->
		<div class="lg:col-span-3 space-y-4">
			<div class="relative bg-canvas border border-hairline rounded-lg shadow-level-2 focus-within:ring-1 focus-within:ring-ink transition-all">
				<textarea
					id={id}
					class="w-full h-[500px] p-6 bg-transparent border-none focus:ring-0 text-body-md font-mono resize-none placeholder:text-mute"
					placeholder={placeholder}></textarea>
				
				<div class="absolute bottom-4 right-4 flex items-center gap-2">
					<button
						id={`copy-${id}`}
						class="h-8 px-3 flex items-center text-body-sm-strong bg-ink text-canvas rounded-pill hover:opacity-90 transition-opacity shadow-sm"
					>
						Copy to Clipboard
					</button>
                    <button
						id={`clear-${id}`}
						class="h-8 px-3 flex items-center text-body-sm-strong bg-canvas text-ink border border-hairline rounded-pill hover:bg-canvas-soft transition-colors shadow-sm"
					>
						Clear
					</button>
				</div>
			</div>

			<div class="flex flex-wrap items-center gap-6 text-caption-mono text-mute">
				<div class="flex items-center gap-2">
					<span>Characters:</span>
					<span id={`${id}-chars`} class="text-ink font-medium">0</span>
				</div>
				<div class="flex items-center gap-2">
					<span>Words:</span>
					<span id={`${id}-words`} class="text-ink font-medium">0</span>
				</div>
				<div class="flex items-center gap-2">
					<span>Lines:</span>
					<span id={`${id}-lines`} class="text-ink font-medium">0</span>
				</div>
			</div>
		</div>

		<!-- Options Pane -->
		<div class="lg:col-span-1 space-y-6">
			<div class="bg-canvas border border-hairline rounded-lg p-6 shadow-level-1">
				<h3 class="text-caption-mono text-mute uppercase mb-4">Actions</h3>
				<div class="flex flex-col gap-2">
                    <slot name="controls" />
				</div>
			</div>

            <div class="bg-canvas-soft-2 rounded-lg p-6 border border-hairline">
                <h4 class="text-body-sm-strong mb-2">Privacy First</h4>
                <p class="text-caption text-body">
                    Your text is processed entirely in your browser. No data is ever sent to a server.
                </p>
            </div>
		</div>
	</div>
</div>

<script is:inline define:vars={{ id }}>
    const textarea = document.getElementById(id);
    const copyBtn = document.getElementById(`copy-${id}`);
    const clearBtn = document.getElementById(`clear-${id}`);
    const charCount = document.getElementById(`${id}-chars`);
    const wordCount = document.getElementById(`${id}-words`);
    const lineCount = document.getElementById(`${id}-lines`);

    function updateStats() {
        const text = textarea.value;
        charCount.textContent = text.length;
        wordCount.textContent = text.trim() === "" ? 0 : text.trim().split(/\s+/).length;
        lineCount.textContent = text === "" ? 0 : text.split(/\n/).length;
    }

    textarea.addEventListener('input', updateStats);

    copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(textarea.value);
        const originalText = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => {
            copyBtn.textContent = originalText;
        }, 2000);
    });

    clearBtn.addEventListener('click', () => {
        textarea.value = '';
        updateStats();
    });
</script>
