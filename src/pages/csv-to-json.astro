---
import BaseLayout from "../layouts/BaseLayout.astro";
import Workspace from "../components/Workspace.astro";

const title = "CSV to JSON Converter — Online Data Utility";
const description = "Convert CSV data into clean, structured JSON arrays instantly. Handle headers, commas, and multi-line CSV entries entirely in your browser.";
---

<BaseLayout title={title} description={description}>
	<Workspace 
		title="CSV to JSON" 
		description="Paste your CSV data below. The first line will be used as the object keys." 
        placeholder="name,age,city\nJohn Doe,30,New York\nJane Smith,25,London"
	>
		<div slot="controls">
			<button
				id="csv-to-json-btn"
                data-action="csv-to-json"
				class="w-full h-10 px-4 flex items-center justify-between text-body-sm-strong bg-ink text-canvas rounded-md hover:opacity-90 transition-opacity group"
			>
				Convert to JSON
				<span class="text-[10px] bg-canvas/20 px-1.5 py-0.5 rounded uppercase tracking-wider group-hover:bg-canvas/30 transition-colors">Action</span>
			</button>
		</div>
	</Workspace>

    <!-- FAQ Section -->
    <section id="faq" class="max-w-[800px] mx-auto px-6 py-20 border-t border-hairline scroll-mt-20">
        <h2 class="text-display-md mb-8 text-center">Frequently Asked Questions</h2>
        
        <div class="space-y-6">
            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">How does CSV to JSON conversion work?</h3>
                <p class="text-body-md text-body">
                    Our tool treats the first row of your CSV as the "Headers" (keys). Each subsequent row is converted into a JSON object where the column values match the headers. The final output is a JSON Array of these objects.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Can it handle large CSV files?</h3>
                <p class="text-body-md text-body">
                    Since the processing happens in your browser, it is limited by your computer's memory. It works perfectly for thousands of rows, but extremely large datasets (100MB+) might cause the browser tab to slow down.
                </p>
            </div>
        </div>
    </section>

    <script>
        document.getElementById('csv-to-json-btn')?.addEventListener('click', () => {
            const textarea = document.getElementById('workspace-textarea') as HTMLTextAreaElement;
            if (!textarea) return;
            
            const input = textarea.value.trim();
            if (!input) return;

            try {
                const lines = input.split('\n').filter(l => l.trim() !== '');
                if (lines.length < 2) throw new Error("Need at least headers and one row");

                const headers = lines[0].split(',').map(h => h.trim());
                const rows = lines.slice(1).map(line => {
                    const values = line.split(',');
                    return headers.reduce((obj: any, header, i) => {
                        obj[header] = values[i]?.trim();
                        return obj;
                    }, {});
                });

                textarea.value = JSON.stringify(rows, null, 2);
                textarea.dispatchEvent(new CustomEvent('workspace:complete'));
            } catch (e) {
                textarea.classList.add('border-red-500');
                setTimeout(() => textarea.classList.remove('border-red-500'), 1000);
            }
        });
    </script>
</BaseLayout>
