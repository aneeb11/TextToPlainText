---
import BaseLayout from "../layouts/BaseLayout.astro";
import Workspace from "../components/Workspace.astro";

const title = "Add Prefix or Suffix to Lines — Free Online Add Prefix or Suffix to Lines | Text to Plain Text";
const description = "Automatically add text, bullet points, or characters to the beginning or end of every line in your list. A fast, privacy-first bulk text editor for lists.";
---

<BaseLayout title={title} description={description}>
    <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "What is Add Prefix & Suffix?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Add Prefix & Suffix is a bulk text editing tool that allows you to prepend or append specific characters, words, or symbols to every line in your text block simultaneously."
        }
      }, {
        "@type": "Question",
        "name": "How does Add Prefix & Suffix work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The tool splits your text into individual lines and applies your specified prefix to the start and suffix to the end of each line, then joins them back together instantly."
        }
      }, {
        "@type": "Question",
        "name": "Is Add Prefix & Suffix free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, this tool is part of the Text to Plain Text suite and is completely free to use without any limitations or account requirements."
        }
      }, {
        "@type": "Question",
        "name": "Is Add Prefix & Suffix safe?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. Like all our tools, processing happens entirely in your browser. Your data is never uploaded to any server, ensuring total privacy."
        }
      }]
    }
    </script>

	<Workspace 
		title="Add Prefix & Suffix" 
		description="Bulk edit every line in your text by adding custom characters to the start or end." 
	>
		<div slot="controls" class="space-y-4">
            <div class="space-y-2">
                <label class="text-caption-mono text-mute uppercase tracking-widest px-1">Prefix</label>
                <input 
                    id="prefix-input"
                    type="text" 
                    placeholder="e.g. - or >"
                    class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-body-sm focus:ring-1 focus:ring-ink outline-none"
                />
            </div>
            <div class="space-y-2">
                <label class="text-caption-mono text-mute uppercase tracking-widest px-1">Suffix</label>
                <input 
                    id="suffix-input"
                    type="text" 
                    placeholder="e.g. ,"
                    class="w-full h-10 px-3 bg-canvas border border-hairline rounded-md text-body-sm focus:ring-1 focus:ring-ink outline-none"
                />
            </div>
			<button
				id="apply-btn"
				class="w-full h-10 px-4 flex items-center justify-between text-body-sm-strong bg-ink text-canvas rounded-md hover:opacity-90 transition-opacity group"
			>
				Apply to All Lines
				<span class="text-[10px] bg-canvas/20 px-1.5 py-0.5 rounded uppercase tracking-wider group-hover:bg-canvas/30 transition-colors">Action</span>
			</button>
		</div>

	<section id="faq" class="max-w-[800px] mx-auto px-6 py-20 border-t border-hairline scroll-mt-20">
    <h2 class="text-display-md mb-8 text-center">Frequently Asked Questions</h2>
    
    <div class="space-y-6">
        <div class="group border-b border-hairline pb-6">
            <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">What is Add Prefix & Suffix?</h3>
            <p class="text-body-md text-body">
                Add Prefix & Suffix is a bulk text editing tool that allows you to prepend or append specific characters, words, or symbols to every line in your text block simultaneously. It's perfect for formatting lists, adding markdown bullets, or appending commas to data.
            </p>
        </div>

        <div class="group border-b border-hairline pb-6">
            <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">How does Add Prefix & Suffix work?</h3>
            <p class="text-body-md text-body">
                The tool splits your input text into individual lines based on line breaks. It then applies your specified prefix to the start and suffix to the end of each line before joining them back into a single text block.
            </p>
        </div>

        <div class="group border-b border-hairline pb-6">
            <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is Add Prefix & Suffix free?</h3>
            <p class="text-body-md text-body">
                Yes, this tool is part of the Text to Plain Text suite and is completely free to use. There are no daily limits, premium features, or sign-up requirements.
            </p>
        </div>

        <div class="group border-b border-hairline pb-6">
            <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is Add Prefix & Suffix safe?</h3>
            <p class="text-body-md text-body">
                Absolutely. Our tool operates entirely client-side using JavaScript. This means your text never leaves your browser and is never stored on our servers, ensuring your data remains private and secure.
            </p>
        </div>
    </div>
</section>
	</Workspace>

<script is:inline>
	const btn = document.getElementById('apply-btn');
	const textarea = document.getElementById('workspace-textarea');
    const prefixInput = document.getElementById('prefix-input');
    const suffixInput = document.getElementById('suffix-input');

	btn.addEventListener('click', () => {
        textarea.dispatchEvent(new Event('workspace:save'));
		const text = textarea.value;
        const prefix = prefixInput.value;
        const suffix = suffixInput.value;

		const cleaned = text
            .split('\n')
            .map(line => `${prefix}${line}${suffix}`)
            .join('\n');
            
		textarea.value = cleaned;
        textarea.dispatchEvent(new Event('input'));
        textarea.dispatchEvent(new Event('workspace:complete'));
	});
</script>
</BaseLayout>
