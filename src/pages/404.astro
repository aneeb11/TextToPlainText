---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "404: Page Not Found — Text to Plain Text";
---

<BaseLayout title={title}>
	<div class="flex flex-col items-center justify-center min-h-[60vh] px-6 text-center">
		<h1 class="text-[120px] font-bold tracking-tighter leading-none mb-4">404.</h1>
		<h2 class="text-display-sm mb-6">Oops! We couldn't find that page.</h2>
		<p class="text-body-lg text-body max-w-[500px] mb-8">
			It looks like the link is broken or the page has been moved. 
			Let's get you back to cleaning some text.
		</p>
		<a 
			href="/" 
			class="h-12 px-8 flex items-center justify-center bg-ink text-canvas rounded-full text-body-md-strong hover:opacity-90 transition-opacity shadow-lg"
		>
			Return to Homepage
		</a>
	</div>
</BaseLayout>
