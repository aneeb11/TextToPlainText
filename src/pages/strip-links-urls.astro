---
import BaseLayout from "../layouts/BaseLayout.astro";
import Workspace from "../components/Workspace.astro";

const title = "Strip Links — Free Online Strip Links | Text to Plain Text";
const description = "Cleanly remove all web addresses and URLs from your text content instantly. A fast, privacy-first tool for cleaning and sanitizing your data.";
---

<BaseLayout title={title} description={description}>
    <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "What is Strip Links?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Strip Links is a data cleaning utility that allows you to instantly remove all web addresses and URL patterns from your text content."
        }
      }, {
        "@type": "Question",
        "name": "How does Strip Links work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The tool identifies URL patterns (such as http, https, and www) and removes them from your text block, helping you sanitize data quickly."
        }
      }, {
        "@type": "Question",
        "name": "Is Strip Links free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, this tool is part of the Text to Plain Text suite and is completely free to use without any limitations or account requirements."
        }
      }, {
        "@type": "Question",
        "name": "Is Strip Links safe?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. Like all our tools, processing happens entirely in your browser. Your data is never uploaded to any server, ensuring total privacy."
        }
      }]
    }
    </script>

	<Workspace 
		title="Remove All URLs" 
		description="Cleanly remove all web addresses and URLs from your text content instantly." 
		id="url-stripper"
	>
		<div slot="controls">
			<button
				id="strip-urls"
				class="w-full h-10 px-4 flex items-center justify-between text-body-sm-strong bg-ink text-canvas rounded-md hover:opacity-90 transition-opacity group"
			>
				Remove All URLs
				<span class="text-[10px] bg-canvas/20 px-1.5 py-0.5 rounded uppercase tracking-wider group-hover:bg-canvas/30 transition-colors">Action</span>
			</button>
		</div>

	<section id="faq" class="max-w-[800px] mx-auto px-6 py-20 border-t border-hairline scroll-mt-20">
        <h2 class="text-display-md mb-8 text-center">Frequently Asked Questions</h2>
        
        <div class="space-y-6">
            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">What is Strip Links?</h3>
                <p class="text-body-md text-body">
                    Strip Links is a data cleaning utility that allows you to instantly remove all web addresses and URL patterns from your text content.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">How does Strip Links work?</h3>
                <p class="text-body-md text-body">
                    The tool identifies URL patterns (such as http, https, and www) and removes them from your text block, helping you sanitize data quickly.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is Strip Links free?</h3>
                <p class="text-body-md text-body">
                    Yes, this tool is part of the Text to Plain Text suite and is completely free to use. There are no daily limits, premium features, or sign-up requirements.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is Strip Links safe?</h3>
                <p class="text-body-md text-body">
                    Absolutely. Our tool operates entirely client-side using JavaScript. This means your text never leaves your browser and is never stored on our servers, ensuring your data remains private and secure.
                </p>
            </div>
        </div>
    </section>
	</Workspace>

<script is:inline>
        const btn = document.getElementById('strip-urls');
        const textarea = document.getElementById('url-stripper');
    
        btn.addEventListener('click', () => {
            textarea.dispatchEvent(new Event('workspace:save'));
            const text = textarea.value;
            // Simple regex to match most URLs
            const urlPattern = /(https?:\/\/[^\s]+|www\.[^\s]+)/gi;
            const cleaned = text.replace(urlPattern, '');
                
            textarea.value = cleaned;
            textarea.dispatchEvent(new Event('input'));
            textarea.dispatchEvent(new Event('workspace:complete'));
        });
    </script>
</BaseLayout>
