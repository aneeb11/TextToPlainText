---
import BaseLayout from "../layouts/BaseLayout.astro";
import Workspace from "../components/Workspace.astro";

const title = "Remove Blank Lines Online — Clean Paragraph Spacing";
const description = "Instantly remove empty lines and white space gaps from your text or code.";
---

<BaseLayout title={title} description={description}>
	<Workspace 
		title="Remove Blank Lines" 
		description="Quickly strip out empty lines and redundant vertical whitespace from your document." 
		id="blank-lines"
	>
		<div slot="controls">
			<button
				id="remove-blanks"
				class="w-full h-10 px-4 flex items-center justify-between text-body-sm-strong bg-ink text-canvas rounded-md hover:opacity-90 transition-opacity group"
			>
				Remove Blank Lines
				<span class="text-[10px] bg-canvas/20 px-1.5 py-0.5 rounded uppercase tracking-wider group-hover:bg-canvas/30 transition-colors">Action</span>
			</button>
		</div>
	</Workspace>
</BaseLayout>

<script is:inline>
	const btn = document.getElementById('remove-blanks');
	const textarea = document.getElementById('blank-lines');

	btn.addEventListener('click', () => {
		const text = textarea.value;
		const cleaned = text
            .split('\n')
            .filter(line => line.trim() !== '')
            .join('\n');
            
		textarea.value = cleaned;
        textarea.dispatchEvent(new Event('input'));
	});
</script>
