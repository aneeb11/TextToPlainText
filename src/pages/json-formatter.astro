---
import BaseLayout from "../layouts/BaseLayout.astro";
import Workspace from "../components/Workspace.astro";

const title = "JSON Formatter — Free Online JSON Formatter | Text to Plain Text";
const description = "Format, beautify, and validate your JSON data instantly. Our JSON Formatter makes messy JSON readable and highlights syntax errors, 100% locally in your browser.";
---

<BaseLayout title={title} description={description}>
    <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "What is JSON Formatter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "JSON Formatter is a developer utility that takes minified or unformatted JSON strings and transforms them into a structured, indented, and human-readable format."
        }
      }, {
        "@type": "Question",
        "name": "How does JSON Formatter work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The tool parses your input string using the standard JSON.parse method and then re-stringifies it with a defined indentation level (2 spaces), ensuring valid syntax and perfect formatting."
        }
      }, {
        "@type": "Question",
        "name": "Is JSON Formatter free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, our JSON Formatter and Validator is completely free to use with no usage limits, registration, or premium tiers."
        }
      }, {
        "@type": "Question",
        "name": "Is JSON Formatter safe?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. Like all our tools, it runs entirely in your browser memory. We never see your data, and nothing is uploaded to our servers, making it safe for sensitive configuration files."
        }
      }]
    }
    </script>

	<Workspace 
		title="JSON Formatter" 
		description="Paste your messy JSON below to beautify and validate it instantly." 
        placeholder='{ "key": "paste your json here" }'
	>
		<div slot="controls">
			<button
				id="format-json-btn"
                data-action="format-json"
				class="w-full h-10 px-4 flex items-center justify-between text-body-sm-strong bg-ink text-canvas rounded-md hover:opacity-90 transition-opacity group"
			>
				Beautify JSON
				<span class="text-[10px] bg-canvas/20 px-1.5 py-0.5 rounded uppercase tracking-wider group-hover:bg-canvas/30 transition-colors">Action</span>
			</button>
		</div>

	<section id="faq" class="max-w-[800px] mx-auto px-6 py-20 border-t border-hairline scroll-mt-20">
        <h2 class="text-display-md mb-8 text-center">Frequently Asked Questions</h2>
        
        <div class="space-y-6">
            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">What is a JSON Formatter?</h3>
                <p class="text-body-md text-body">
                    A JSON Formatter is a specialized tool that transforms raw, unformatted, or minified JSON strings into a human-readable format with proper indentation, spacing, and structured line breaks. It's a fundamental utility for developers working with APIs and data files.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">How does the JSON Formatter work?</h3>
                <p class="text-body-md text-body">
                    Our tool utilizes the browser's built-in JSON parsing engine. It first validates that your input is a legitimate JSON structure and then re-generates the string with standard 2-space indentation, making nested objects and arrays easy to visualize.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is JSON Formatter free?</h3>
                <p class="text-body-md text-body">
                    Yes, our JSON Formatter is 100% free. We believe in providing high-quality developer tools without the need for accounts, subscriptions, or any usage fees.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is this tool safe for sensitive data?</h3>
                <p class="text-body-md text-body">
                    Absolutely. Unlike many online formatters, all processing is performed locally in your web browser. Your JSON data is never sent to any server, making it perfectly safe for formatting credentials, personal information, or proprietary code.
                </p>
            </div>
        </div>
    </section>
	</Workspace>

<script>
        document.getElementById('format-json-btn')?.addEventListener('click', () => {
            const textarea = document.getElementById('workspace-textarea') as HTMLTextAreaElement;
            if (!textarea) return;
            
            try {
                const parsed = JSON.parse(textarea.value);
                textarea.value = JSON.stringify(parsed, null, 2);
                textarea.dispatchEvent(new CustomEvent('workspace:complete'));
            } catch (e) {
                textarea.classList.add('border-red-500');
                setTimeout(() => textarea.classList.remove('border-red-500'), 1000);
            }
        });
    </script>
</BaseLayout>
