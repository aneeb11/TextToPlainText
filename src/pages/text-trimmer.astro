---
import BaseLayout from "../layouts/BaseLayout.astro";
import Workspace from "../components/Workspace.astro";

const title = "Text Trimmer — Free Online Text Trimmer | Text to Plain Text";
const description = "Truncate and trim your text to specific character or word limits for social media, SEO meta descriptions, and messaging. Precise cutting to ensure content fits.";
---

<BaseLayout title={title} description={description}>
    <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "What is Text Trimmer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Text Trimmer is a utility for truncating your text to specific character or word limits, ensuring it fits perfectly for social media posts, SEO meta descriptions, or messaging limits."
        }
      }, {
        "@type": "Question",
        "name": "How does Text Trimmer work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The tool slices your text string at your chosen character or word limit, and adds an ellipsis (...) if the original text was longer than the limit."
        }
      }, {
        "@type": "Question",
        "name": "Is Text Trimmer free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, this tool is part of the Text to Plain Text suite and is completely free to use without any limitations or account requirements."
        }
      }, {
        "@type": "Question",
        "name": "Is Text Trimmer safe?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. Like all our tools, processing happens entirely in your browser. Your data is never uploaded to any server, ensuring total privacy."
        }
      }]
    }
    </script>

	<Workspace 
		title="Text Truncator & Trimmer" 
		description="Set your character or word limit and truncate your text instantly. Perfect for social media, SEO meta descriptions, and messaging." 
	>
		<div slot="controls" class="space-y-6">
            <div class="space-y-2">
                <label class="text-[10px] font-bold text-mute uppercase tracking-widest px-1">Character Presets</label>
                <div class="grid grid-cols-2 gap-2">
                    <button
                        class="trim-preset h-9 px-3 text-[11px] font-semibold border border-hairline rounded-md hover:bg-canvas-soft-2 transition-colors"
                        data-limit="280"
                        data-type="chars"
                    >
                        Twitter (280)
                    </button>
                    <button
                        class="trim-preset h-9 px-3 text-[11px] font-semibold border border-hairline rounded-md hover:bg-canvas-soft-2 transition-colors"
                        data-limit="160"
                        data-type="chars"
                    >
                        SMS (160)
                    </button>
                    <button
                        class="trim-preset h-9 px-3 text-[11px] font-semibold border border-hairline rounded-md hover:bg-canvas-soft-2 transition-colors"
                        data-limit="160"
                        data-type="chars"
                    >
                        Meta Desc (160)
                    </button>
                    <button
                        class="trim-preset h-9 px-3 text-[11px] font-semibold border border-hairline rounded-md hover:bg-canvas-soft-2 transition-colors"
                        data-limit="60"
                        data-type="chars"
                    >
                        SEO Title (60)
                    </button>
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-bold text-mute uppercase tracking-widest px-1">Word Presets</label>
                <div class="grid grid-cols-2 gap-2">
                    <button
                        class="trim-preset h-9 px-3 text-[11px] font-semibold border border-hairline rounded-md hover:bg-canvas-soft-2 transition-colors"
                        data-limit="50"
                        data-type="words"
                    >
                        50 Words
                    </button>
                    <button
                        class="trim-preset h-9 px-3 text-[11px] font-semibold border border-hairline rounded-md hover:bg-canvas-soft-2 transition-colors"
                        data-limit="100"
                        data-type="words"
                    >
                        100 Words
                    </button>
                    <button
                        class="trim-preset h-9 px-3 text-[11px] font-semibold border border-hairline rounded-md hover:bg-canvas-soft-2 transition-colors"
                        data-limit="250"
                        data-type="words"
                    >
                        250 Words
                    </button>
                    <button
                        class="trim-preset h-9 px-3 text-[11px] font-semibold border border-hairline rounded-md hover:bg-canvas-soft-2 transition-colors"
                        data-limit="500"
                        data-type="words"
                    >
                        500 Words
                    </button>
                </div>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-bold text-mute uppercase tracking-widest px-1">Custom Truncate</label>
                <div class="flex flex-wrap gap-2">
                    <input 
                        type="number" 
                        id="custom-limit-input"
                        placeholder="Limit..."
                        class="flex-grow min-w-[80px] h-10 px-3 bg-canvas border border-hairline rounded-md text-body-sm outline-none focus:ring-1 focus:ring-ink"
                    />
                    <select id="custom-type-select" class="flex-grow sm:flex-grow-0 h-10 px-2 bg-canvas border border-hairline rounded-md text-body-sm outline-none">
                        <option value="chars">Chars</option>
                        <option value="words">Words</option>
                    </select>
                    <button
                        id="trim-custom-btn"
                        class="w-full sm:w-auto h-10 px-4 bg-ink text-canvas rounded-md text-body-sm-strong hover:opacity-90 transition-opacity cursor-pointer"
                    >
                        Truncate
                    </button>
                </div>
            </div>
		</div>

	<section id="faq" class="max-w-[800px] mx-auto px-6 py-20 border-t border-hairline scroll-mt-20">
        <h2 class="text-display-md mb-8 text-center">Frequently Asked Questions</h2>
        
        <div class="space-y-6">
            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">What is Text Trimmer?</h3>
                <p class="text-body-md text-body">
                    Text Trimmer is a utility for truncating your text to specific character or word limits, ensuring it fits perfectly for social media posts, SEO meta descriptions, or messaging limits.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">How does Text Trimmer work?</h3>
                <p class="text-body-md text-body">
                    The tool slices your text string at your chosen character or word limit, and adds an ellipsis (...) if the original text was longer than the limit.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is Text Trimmer free?</h3>
                <p class="text-body-md text-body">
                    Yes, this tool is part of the Text to Plain Text suite and is completely free to use. There are no daily limits, premium features, or sign-up requirements.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is Text Trimmer safe?</h3>
                <p class="text-body-md text-body">
                    Absolutely. Our tool operates entirely client-side using JavaScript. This means your text never leaves your browser and is never stored on our servers, ensuring your data remains private and secure.
                </p>
            </div>
        </div>
    </section>
	</Workspace>

<script>
        const textarea = document.getElementById('workspace-textarea') as HTMLTextAreaElement;
        
        const applyTrim = (limit: number, type: string) => {
            if (!textarea) return;
            const input = textarea.value.trim();
            if (!input) return;

            if (type === 'chars') {
                textarea.value = input.slice(0, limit);
            } else {
                const words = input.split(/\s+/);
                textarea.value = words.slice(0, limit).join(' ') + (words.length > limit ? '...' : '');
            }
            
            textarea.dispatchEvent(new CustomEvent('workspace:complete'));
        };

        // Preset Listeners
        document.querySelectorAll('.trim-preset').forEach(btn => {
            btn.addEventListener('click', () => {
                const limit = parseInt(btn.getAttribute('data-limit') || "0");
                const type = btn.getAttribute('data-type') || "chars";
                if (limit > 0) applyTrim(limit, type);
            });
        });

        // Custom Limit Listener
        document.getElementById('trim-custom-btn')?.addEventListener('click', () => {
            const input = document.getElementById('custom-limit-input') as HTMLInputElement;
            const select = document.getElementById('custom-type-select') as HTMLSelectElement;
            const limit = parseInt(input.value);
            const type = select.value;
            if (limit > 0) applyTrim(limit, type);
        });
    </script>
</BaseLayout>
