---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "500: Server Error — Text to Plain Text";
---

<BaseLayout title={title}>
	<div class="flex flex-col items-center justify-center min-h-[60vh] px-6 text-center">
		<h1 class="text-[120px] font-bold tracking-tighter leading-none mb-4">500.</h1>
		<h2 class="text-display-sm mb-6">Something went wrong on our end.</h2>
		<p class="text-body-lg text-body max-w-[500px] mb-8">
			We're experiencing a technical issue. Don't worry, your data is safe since it's processed in your browser. 
			Please try refreshing the page.
		</p>
		<div class="flex gap-4">
			<button 
				onclick="window.location.reload()"
				class="h-12 px-8 flex items-center justify-center bg-ink text-canvas rounded-full text-body-md-strong hover:opacity-90 transition-opacity shadow-lg"
			>
				Refresh Page
			</button>
			<a 
				href="/" 
				class="h-12 px-8 flex items-center justify-center bg-canvas text-ink border border-hairline rounded-full text-body-md-strong hover:bg-canvas-soft transition-colors shadow-sm"
			>
				Go Home
			</a>
		</div>
	</div>
</BaseLayout>
