---
import BaseLayout from "../layouts/BaseLayout.astro";
import Workspace from "../components/Workspace.astro";

const title = "JSON Minifier — Free Online JSON Minifier | Text to Plain Text";
const description = "Minify and compress your JSON data to reduce file size instantly. Our JSON Minifier removes all unnecessary whitespace 100% locally in your browser.";
---

<BaseLayout title={title} description={description}>
    <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{
        "@type": "Question",
        "name": "What is JSON Minifier?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "JSON Minifier is a tool that removes all unnecessary whitespace, tabs, and newlines from a JSON string to create the smallest possible file size for production data transfer."
        }
      }, {
        "@type": "Question",
        "name": "How does JSON Minifier work?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The tool parses the JSON input and then re-stringifies it without any indentation or spacing, resulting in a condensed, single-line representation of the data."
        }
      }, {
        "@type": "Question",
        "name": "Is JSON Minifier free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, our JSON Minifier is completely free to use with no usage limits or registration required."
        }
      }, {
        "@type": "Question",
        "name": "Is JSON Minifier safe?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. The minification process happens entirely within your browser. Your JSON data is never sent to our servers, keeping your information private."
        }
      }]
    }
    </script>

	<Workspace 
		title="JSON Minifier" 
		description="Paste your JSON below to strip all whitespace and minify it for production." 
        placeholder='{ "key": "value" }'
	>
		<div slot="controls">
			<button
				id="minify-json-btn"
                data-action="minify-json"
				class="w-full h-10 px-4 flex items-center justify-between text-body-sm-strong bg-ink text-canvas rounded-md hover:opacity-90 transition-opacity group"
			>
				Minify JSON
				<span class="text-[10px] bg-canvas/20 px-1.5 py-0.5 rounded uppercase tracking-wider group-hover:bg-canvas/30 transition-colors">Action</span>
			</button>
		</div>

	<section id="faq" class="max-w-[800px] mx-auto px-6 py-20 border-t border-hairline scroll-mt-20">
        <h2 class="text-display-md mb-8 text-center">Frequently Asked Questions</h2>
        
        <div class="space-y-6">
            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">What is JSON Minification?</h3>
                <p class="text-body-md text-body">
                    JSON Minification is the process of stripping out all formatting characters—like spaces, tabs, and newlines—that are added for human readability but are not required for a computer to understand the data. This reduces the total byte size of the file.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">How does the JSON Minifier work?</h3>
                <p class="text-body-md text-body">
                    Our tool uses a JavaScript engine to parse your input string into a structured object. It then converts that object back into a string without any optional whitespace, creating a compact version that is ready for production APIs and storage.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is JSON Minifier free?</h3>
                <p class="text-body-md text-body">
                    Yes, JSON Minifier is part of the Text to Plain Text suite and is 100% free. We provide these developer utilities without charging or requiring any user information.
                </p>
            </div>

            <div class="group border-b border-hairline pb-6">
                <h3 class="text-body-lg font-semibold mb-2 group-hover:text-ink transition-colors">Is JSON Minifier safe?</h3>
                <p class="text-body-md text-body">
                    Absolutely. Privacy and security are our priorities. All minification is performed client-side on your device. Your data never leaves your browser, ensuring it remains confidential and secure.
                </p>
            </div>
        </div>
    </section>
	</Workspace>

<script>
        document.getElementById('minify-json-btn')?.addEventListener('click', () => {
            const textarea = document.getElementById('workspace-textarea') as HTMLTextAreaElement;
            if (!textarea) return;
            
            try {
                const parsed = JSON.parse(textarea.value);
                textarea.value = JSON.stringify(parsed);
                textarea.dispatchEvent(new CustomEvent('workspace:complete'));
            } catch (e) {
                textarea.classList.add('border-red-500');
                setTimeout(() => textarea.classList.remove('border-red-500'), 1000);
            }
        });
    </script>
</BaseLayout>
